@page "/"
@using Microsoft.Extensions.Options
@using MyFirstAzureApp.Config
@inject IOptions<AppSettings> Options
@inject IConfiguration Configuration


<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app. 

<div class="d-flex flex-column">    
    <span>ApiUrl: @Options.Value.ApiUrl</span>
    <span>JwtSecret: @Options.Value.JwtSecret</span>
    <span>ApiKey: @Options.Value.ApiKey</span>
    <span>Connection string: @Configuration.GetConnectionString("DbConnection")</span>
</div>
